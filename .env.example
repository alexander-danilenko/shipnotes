SHIPNOTES_JIRA_BASE_URL=https://your-company.atlassian.net
SHIPNOTES_JIRA_EMAIL=your-email@example.com
SHIPNOTES_JIRA_TOKEN=your-jira-api-token
# Optional: the GitHub repository used to build commit and pull-request links.
# Accepts a URL, an SSH remote, or the "org/repo" shorthand. Inferred from the
# repository's git remote when unset.
# SHIPNOTES_GITHUB_REPO=your-org/your-repo
